
[Unit]
Description=rtk_hciattach
DefaultDependencies=no
After=local-fs.target
Before=atrios-ramlog.target
Conflicts=shutdown.target

[Service]
Type=oneshot
ExecStart=/usr/bin/bash /usr/lib/atrios/jethub-rtk-hciattach-starter
RemainAfterExit=yes
TimeoutStartSec=30sec

[Install]
WantedBy=sysinit.target
